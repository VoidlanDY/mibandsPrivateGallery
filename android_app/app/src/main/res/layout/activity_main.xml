<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml - Private Gallery Companion main layout

  Design note: The app clearly labels "normal" and "private" sections,
  as this is the ONLY place where the dual-mode existence is visible.
  The watch never exposes this distinction.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="私密图库助手"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="小米手环9 Pro · 图片管理"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:paddingBottom="20dp" />

        <!-- Connection Status -->
        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="正在检查手表连接..."
            android:textSize="13sp"
            android:textColor="#CCCCCC"
            android:gravity="center"
            android:padding="8dp"
            android:background="#FF222244"
            android:layout_marginBottom="16dp" />

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="100"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- ======================================================== -->
        <!-- NORMAL GALLERY SECTION -->
        <!-- ======================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2A2A4A"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📁 普通图库"
                android:textSize="18sp"
                android:textColor="#FF66AAFF"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/normal_count_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="普通图库: 0 张图片"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_import_normal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="导入图片"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#FF4466BB" />

                <Button
                    android:id="@+id/btn_set_normal_pw"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="设置密码"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#FF4466BB" />
            </LinearLayout>

        </LinearLayout>

        <!-- ======================================================== -->
        <!-- PRIVATE GALLERY SECTION -->
        <!-- ======================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF3A1A1A"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔒 私密图库"
                android:textSize="18sp"
                android:textColor="#FFFF6666"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠ 手表端不会显示此标签，仅在此App可见"
                android:textSize="11sp"
                android:textColor="#FF884444"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/private_count_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="私密图库: 0 张图片"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_import_private"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="导入图片"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#FFBB4444" />

                <Button
                    android:id="@+id/btn_set_private_pw"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="设置密码"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#FFBB4444" />
            </LinearLayout>

        </LinearLayout>

        <!-- ======================================================== -->
        <!-- VERIFY SECTION -->
        <!-- ======================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF222244"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔍 密码验证"
                android:textSize="16sp"
                android:textColor="#FFCCCCCC"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="验证某个密码在手环上会显示哪种图库"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/btn_verify"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="验证密码"
                android:backgroundTint="#FF555555" />

        </LinearLayout>

        <!-- ======================================================== -->
        <!-- INSTRUCTIONS -->
        <!-- ======================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF1A1A2E"
            android:padding="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="使用说明"
                android:textSize="14sp"
                android:textColor="#FF888888"
                android:textStyle="bold"
                android:paddingBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. 确保手表通过USB或WiFi ADB连接到手机\n"
                        + "2. 设置两个不同的6位数字密码\n"
                        + "3. 分别导入普通图片和私密图片\n"
                        + "4. 在手表上打开图库，输入密码即可查看\n\n"
                        + "隐私安全提示：\n"
                        + "• 手表端所有界面完全相同，不会暴露模式\n"
                        + "• 输入普通密码 → 显示普通图片\n"
                        + "• 输入私密密码 → 显示私密图片\n"
                        + "• 任何人拿到手表都无法判断是否存在两种图库\n"
                        + "• 连续输错5次将锁定30秒\n"
                        + "• 密码使用SHA-256哈希存储，不可逆"
                android:textSize="11sp"
                android:textColor="#FF666666" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
